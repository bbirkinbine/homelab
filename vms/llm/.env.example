# vms/llm/.env.example
#
# Copy to vms/llm/.env and fill in. The .env file is gitignored
# (matched by /.env* in the repo's top-level .gitignore).

# ---- Proxmox connection (deploy.sh runs from your Mac, ssh's to the node) ----
PROXMOX_HOST="pve12.lan"          # SSH hostname or IP for the Proxmox node
PROXMOX_NODE="pve12"              # Cluster node name (qm operates on this)
SSH_USER="root"                   # SSH user; must be able to run `qm` and `pvesh`

# ---- Source template ----
TEMPLATE_VM_ID="9100"             # ID of the ubuntu-24-04-base template

# ---- New VM identity ----
VM_ID="120"                       # Unique on the Proxmox node
VM_NAME="llm"                     # Used as Proxmox VM name AND cloud-init hostname

# ---- Sizing (resize-able later via `qm set` / `qm resize`) ----
# The 1260P is 4P+8E (12c/16t). 6 vCPU leaves the host enough for Proxmox +
# other VMs; LLM inference on a passthrough GPU barely uses CPU anyway
# (tokenization, sampling, KV-cache bookkeeping, HTTP serving).
VM_CORES="6"
# 32 GiB lets you mmap any model the 3090 can run (24 GB VRAM ceiling) plus
# headroom for OS, Docker, vector DB, etc. Drop to 16 GiB if you need to
# share more RAM with other VMs.
VM_MEMORY="32768"                 # MB
# Models eat space: a 30B Q4 ≈ 18 GB, a 70B Q4 ≈ 40 GB, plus quants you'll
# inevitably hoard. 300 GB is a comfortable starting floor.
VM_DISK_SIZE="300G"
# MUST be 0 — PCIe passthrough requires the VM's RAM to be pinned.
VM_BALLOON="0"

# ---- Storage / cloud-init delivery ----
VM_STORAGE_POOL="local-lvm"       # Where the cloned disk lives
SNIPPETS_STORAGE="local"          # Storage with 'snippets' content type enabled.
                                  # Datacenter -> Storage -> <name> -> Edit -> Content (check Snippets)

# ---- Machine type ----
# q35 is recommended for PCIe passthrough. The base template doesn't pin a
# machine type, so we set it explicitly here. SeaBIOS (the template default)
# stays — switching to OVMF would require an EFI disk and a fresh install.
VM_MACHINE="q35"

# ---- GPU passthrough ----
# PREREQUISITE: the Proxmox host must already have IOMMU enabled and the
# GPU bound to vfio-pci with NVIDIA / nouveau blacklisted. This is a
# one-time per-host setup — see ../../docs/proxmox-gpu-passthrough.md
# for the runbook. deploy.sh will refuse to proceed if the GPU isn't
# bound to vfio-pci.
#
# PCI address of the GPU on the Proxmox host. Find with:
#   ssh root@<proxmox-host> 'lspci -nn | grep -i nvidia'
# Pass the parent address and Proxmox grabs both the GPU and its
# companion HDMI-audio function. Prefix with the domain ("0000:") only
# if your host has multiple PCI domains. For Thunderbolt eGPUs, the
# bus address can shift after enclosure swaps or port changes — re-check
# after physical changes.
#
# Default below is pve12's actual address (RTX 3090 over Thunderbolt 4
# on the i7-1260P). For a different host, run the lspci command above
# and replace.
GPU_PCI_ADDRESS="3c:00"
# pcie=1   — expose as a PCIe device (required for modern GPUs)
# Add x-vga=1 ONLY if this VM uses the GPU as its primary display.
# For headless inference, leave it off.
GPU_HOSTPCI_OPTS="pcie=1"

# ---- First-boot user (cloud-init injects key, sudo, no password) ----
ADMIN_USERNAME="llm-admin"
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... your-key-here"

# Note on NVIDIA driver: cloud-init runs `ubuntu-drivers install --gpgpu`
# inside the VM, which auto-picks the current recommended server-branch
# driver. No version is pinned here — server branches are LTS-cycle and
# the recommended one tracks Ubuntu's hardware-detection database. To
# pin a specific branch, hand-edit cloud-init/user-data.yaml.
