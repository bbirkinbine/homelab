# .env.example — copy to .env and fill in. DO NOT commit a populated .env.
#
# Required
# ---------
PROXMOX_URL="https://nuc12.lan:8006/api2/json"
PROXMOX_TOKEN_ID="packer@pve!builder"
PROXMOX_TOKEN_SECRET="00000000-0000-0000-0000-000000000000"
PROXMOX_NODE="nuc12"

# Optional — uncomment to override the HCL defaults
# ----------------------------------------------------
#PROXMOX_SKIP_TLS_VERIFY="true"
#VM_ID="9100"
#VM_NAME="ubuntu-24-04-base"
#VM_CORES="2"
#VM_MEMORY="2048"
#VM_DISK_SIZE="20G"
#VM_STORAGE_POOL="local-lvm"
#VM_BRIDGE="vmbr0"
#VLAN_TAG=""

# ISO source — pick ONE of these strategies:
#
# Strategy A (default): use an ISO already uploaded to Proxmox
#ISO_FILE="local:iso/ubuntu-24.04.1-live-server-amd64.iso"
#
# Strategy B: have Proxmox download the ISO into a storage pool
#ISO_FILE=""
#ISO_URL="https://releases.ubuntu.com/24.04/ubuntu-24.04.1-live-server-amd64.iso"
#ISO_CHECKSUM="sha256:e240e4b801f7bb68c20d1356b60968ad0c33a41d00d828e74ceb3364a0317be9"
#ISO_STORAGE_POOL="local"

# Build-time SSH credentials. The 'packer' user is created by autoinstall,
# used by Packer to run provisioners, and DELETED before template conversion.
# If you change BUILD_PASSWORD, regenerate the hash in http/user-data:
#   python3 -c "import crypt; print(crypt.crypt('NEWPASS', crypt.mksalt(crypt.METHOD_SHA512)))"
#BUILD_USERNAME="packer"
#BUILD_PASSWORD="packer-build-only"
